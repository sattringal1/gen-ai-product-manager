# ============================================================
# Gen-AI Product Manager — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider ---
# Set to "openai" (default) or "azure_openai"
LLM_PROVIDER=openai

# Option A: OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-replace-with-your-key
OPENAI_MODEL=gpt-4o

# Option B: Azure OpenAI (required when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Jira Integration (optional) ---
JIRA_BASE_URL=https://YOUR-ORG.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PM

# --- Confluence Integration (optional) ---
CONFLUENCE_BASE_URL=https://YOUR-ORG.atlassian.net/wiki
CONFLUENCE_EMAIL=you@company.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=PROD

# --- App Settings ---
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# --- Security ---
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
